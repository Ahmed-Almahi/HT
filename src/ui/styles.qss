/* styles.qss */
QMainWindow {
    background-color: #2b2b2b;
}

QLabel {
    color: #ffffff;
    font-size: 14px;
    font-weight: bold;
}

QLineEdit {
    background-color: #3b3b3b;
    color: #00ff00;
    border: 1px solid #555;
    padding: 5px;
    border-radius: 4px;
}

QPushButton {
    background-color: #0055ff;
    color: white;
    padding: 10px;
    border-radius: 5px;
    font-size: 16px;
}

QRadioButton {
    color: white;
}

QPushButton:hover {
    background-color: #0044cc;
}